      font-size: 1.4rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      color: var(--maroon);
      text-transform: uppercase;
      text-decoration: none;
    }

    .logo span { color: var(--gold); }

    .nav-links {
      display: flex;
      gap: 2.8rem;
      list-style: none;
      align-items: center;
    }

    .nav-links a {
      color: var(--black);
      text-decoration: none;
      font-size: 0.82rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      position: relative;
      transition: all 0.3s ease;
    }

    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -5px;
      left: 0;
      width: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--maroon), var(--gold));
      transition: width 0.4s ease;
    }

    .nav-links a:hover {

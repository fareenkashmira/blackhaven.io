      justify-content: space-between;
      align-items: center;
      backdrop-filter: blur(16px);
      background: rgba(255, 255, 255, 0.95);
      border-bottom: 1px solid rgba(128, 0, 32, 0.1);
      box-shadow: 0 2px 20px rgba(0, 0, 0, 0.05);

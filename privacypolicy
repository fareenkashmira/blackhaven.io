  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --white: #ffffff;
      --black: #000000;
      --maroon: #800020;
      --gold: #e5bb61;
      --baby-pink: #f4c6cf;
      --baby-pink-deep: #e8a4b0;
      --baby-pink-pale: #fdf0f2;
      --grey: #6a6a6a;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background-color: var(--white);
      color: var(--black);
      line-height: 1.8;
      cursor: none;
    }

    .custom-cursor {
      position: fixed;
      width: 8px;
      height: 8px;
      background-color: var(--gold);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9999;
      opacity: 0;
      transform: translate(-50%, -50%);
      transition: opacity 0.3s ease, width 0.2s ease, height 0.2s ease, background-color 0.2s ease;
      box-shadow: 0 0 12px rgba(229, 187, 97, 0.6), 0 0 24px rgba(229, 187, 97, 0.3);
    }

    .custom-cursor.active { opacity: 1; }
    .custom-cursor.hovering {
      width: 16px;
      height: 16px;
      background-color: var(--baby-pink-deep);
    }

    @media (hover: none) and (pointer: coarse) {
      body { cursor: auto; }
      .custom-cursor { display: none; }
    }

    .magnify-target {
      transition: transform 0.2s ease;
      display: inline-block;
    }

    ::selection {
      background: var(--baby-pink);
      color: var(--maroon);
    }

    nav {
